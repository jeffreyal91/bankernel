            <column name="devedor_email" type="varchar(200)">
                <constraints nullable="true" />
            </column>
            <column name="devedor_documento" type="varchar(14)">
                <constraints nullable="true" />
            </column>
            <column name="devedor_nome" type="varchar(200)">
                <constraints nullable="true" />
            </column>
            <column name="devedor_telefone" type="varchar(20)">
                <constraints nullable="true" />
            </column>
            <column name="devedor_cep" type="varchar(8)">
                <constraints nullable="true" />
            </column>
            <column name="devedor_uf" type="varchar(2)">
                <constraints nullable="true" />
            </column>
            <column name="devedor_cidade" type="varchar(100)">
                <constraints nullable="true" />
