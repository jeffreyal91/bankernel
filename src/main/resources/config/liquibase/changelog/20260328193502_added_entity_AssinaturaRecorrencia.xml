    <!--
        Added the entity AssinaturaRecorrencia.
    -->
    <changeSet id="20260328193502-1" author="jhipster">
        <createTable tableName="cob_assinatura_recorrencia">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="numero_ordem" type="varchar(50)">
